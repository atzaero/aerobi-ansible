# Virtual host: {{ vaultwarden_domain }}
# Gerado automaticamente pelo Ansible — não edite manualmente.
# Para modificar, edite: roles/vaultwarden/templates/vhost.conf.j2
#
# NOTA: O bloco SSL abaixo será adicionado automaticamente pelo Certbot
# após a emissão do certificado.

server {
    listen 80;
    server_name {{ vaultwarden_domain }};

    # Limite de tamanho para anexos (padrão Bitwarden: 1GB, ajuste conforme necessário)
    client_max_body_size 128M;

    # Painel /admin restrito à tailnet Headscale (range CGNAT 100.64.0.0/10).
    # Acesso externo retorna 403 — Bitwarden mobile/extensão usam apenas /
    # e continuam funcionando publicamente.
    location /admin {
        allow 100.64.0.0/10;
        allow 127.0.0.1;
        deny all;

        proxy_pass         http://127.0.0.1:{{ vaultwarden_port }};
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    location / {
        proxy_pass         http://127.0.0.1:{{ vaultwarden_port }};
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # WebSocket — necessário para notificações em tempo real
        proxy_http_version 1.1;
        proxy_set_header   Upgrade    $http_upgrade;
        proxy_set_header   Connection "upgrade";

        # Timeouts generosos para operações longas
        proxy_read_timeout  90s;
        proxy_connect_timeout 90s;
        proxy_send_timeout  90s;
    }
}
