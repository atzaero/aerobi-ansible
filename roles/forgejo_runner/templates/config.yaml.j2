# {{ ansible_managed }}
# Config do Forgejo Actions Runner. WORKDIR do container = /data.
log:
  level: {{ forgejo_runner_log_level }}

runner:
  file: .runner
  # Jobs simultâneos. Limitado para não saturar a VPS de produção.
  capacity: {{ forgejo_runner_capacity }}
  timeout: 3h
  insecure: false
  fetch_timeout: 5s
  fetch_interval: 2s
  # Vazio: usa as labels definidas no register (.runner).
  labels: []

cache:
  # Cache server embutido (para actions/cache). Auto-detecta host na rede docker.
  enabled: true

container:
  # SEM rede fixa: cada job/serviço roda numa rede isolada criada pelo runner.
  # NÃO usar a warpgate aqui — um service `postgres` de teste colidiria por
  # nome com o postgres de PRODUÇÃO na warpgate (o job bateria no DB de prod).
  # O deploy (futuro) não precisa do job na warpgate: roda `docker compose`
  # via o sock do host e os containers deployados entram na warpgate pelo
  # próprio compose (networks.external). Isolamento por job é o correto p/ CI.
  network: ""
  privileged: false
  # Injeta o socket do host em cada job → steps podem rodar docker build/compose.
  options: "-v /var/run/docker.sock:/var/run/docker.sock"
  valid_volumes:
    - /var/run/docker.sock
  force_pull: false

host:
  workdir_parent: ""
