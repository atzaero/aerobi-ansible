# Virtual host: {{ vhost_domain }}
# Gerado automaticamente pelo Ansible — não edite manualmente.
# Para modificar, edite: roles/nginx_vhost/templates/vhost.conf.j2
#
# NOTA: O bloco SSL abaixo será adicionado automaticamente pelo Certbot
# após a emissão do certificado.

server {
    listen 80;
    server_name {{ vhost_domain }};

{% if vhost_client_max_body_size is defined %}
    # Tamanho máximo de upload (override default 1m do nginx).
    client_max_body_size {{ vhost_client_max_body_size }};

{% endif %}
    location / {
{% if vhost_tailnet_only | default(false) | bool %}
        # Acesso restrito à tailnet Headscale (range CGNAT 100.64.0.0/10).
        # Externo retorna 403. Mesmo padrão do vault.aerobi.com.br/admin.
        allow 100.64.0.0/10;
        allow 127.0.0.1;
        deny all;

{% endif %}
        proxy_pass         http://127.0.0.1:{{ vhost_port }};
        # HTTP/1.1 + keep-alive ao upstream. Default do nginx é 1.0 (sem
        # keep-alive) — browsers fazendo várias requests paralelas (Next.js
        # standalone serve 8-10 chunks JS por página) esgotam o pool de
        # sockets do upstream Bun/Node, causando timeouts e respostas vazias.
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # Timeouts: defaults do nginx (60s read) são curtos pra apps Node/Bun
        # com SSR/RSC streaming. 90s cobre cold start sem inflar tail latency.
        proxy_connect_timeout 30s;
        proxy_send_timeout    30s;
        proxy_read_timeout    90s;

        # Buffers: chunks JS do Next podem passar de 200KB. Defaults
        # (8x4k = 32k) forçam spool em disco e fragmentação.
        proxy_buffer_size       16k;
        proxy_buffers           8 16k;
        proxy_busy_buffers_size 32k;
{% if vhost_websocket_enabled | default(false) | bool %}

        # WebSocket upgrade — apps que precisam (MinIO console, Uptime Kuma).
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        "upgrade";
{% else %}

        # Sem WebSocket: Connection vazio garante keep-alive limpo.
        proxy_set_header   Connection        "";
{% endif %}
    }
}
