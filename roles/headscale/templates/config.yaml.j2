# Headscale config — gerado pelo Ansible. Não editar manualmente.
# Para modificar: roles/headscale/templates/config.yaml.j2

server_url: https://{{ headscale_domain }}
listen_addr: 0.0.0.0:8080
metrics_listen_addr: 127.0.0.1:9090

# Endereços Tailscale para a tailnet (CGNAT range padrão)
prefixes:
  v4: 100.64.0.0/10
  v6: fd7a:115c:a1e0::/48
  allocation: sequential

# DERP — relays para NAT traversal. DERP embarcado do próprio Headscale
# (aerobi-ansible#135): os relays PÚBLICOS da Tailscale são instáveis/não
# suportados p/ Headscale e o peering CI runner↔VPS não fechava (SSH timeout no
# deploy). O DERP embarcado serve o HTTPS pelo server_url (porta 443 já exposta)
# e o STUN em UDP 3478 (liberar no firewall). `automatically_add_embedded_derp_region`
# injeta a região própria no DERP map; `urls: []` remove os relays públicos.
derp:
  server:
    enabled: true
    region_id: {{ headscale_derp_region_id | default(999) }}
    region_code: "{{ headscale_derp_region_code | default('aerobi') }}"
    region_name: "{{ headscale_derp_region_name | default('Aerobi Embedded DERP') }}"
    stun_listen_addr: "0.0.0.0:{{ headscale_derp_stun_port | default(3478) }}"
    private_key_path: /var/lib/headscale/derp_server_private.key
    automatically_add_embedded_derp_region: true
    ipv4: "{{ headscale_derp_ipv4 | default(ansible_default_ipv4.address | default('')) }}"
  urls: []
  paths: []
  auto_update_enabled: false
  update_frequency: 24h

disable_check_updates: true
ephemeral_node_inactivity_timeout: 30m

# Banco de dados PostgreSQL (compartilhado com outras apps na mesma VPS)
database:
  type: postgres
  postgres:
    host: {{ postgres_container_name }}
    port: 5432
    name: {{ headscale_db }}
    user: {{ headscale_db_user }}
    pass: {{ vault_headscale_db_password }}
    ssl: false

# Logs
log:
  format: text
  level: info

# Política ACL (carregada em runtime; rebuild ao alterar acl.json)
policy:
  mode: file
  path: /etc/headscale/acl.json

# DNS — MagicDNS para resolver hostnames da tailnet
dns:
  magic_dns: true
  base_domain: aerobi.tailnet
  nameservers:
    global:
      - 1.1.1.1
      - 8.8.8.8

  # Override DNS para domínios públicos que devem ser resolvidos pelo IP
  # da tailnet quando o cliente está conectado. Sem isso, o navegador
  # resolve `<sub>.aerobi.com.br` pelo DNS público, o request sai pela
  # internet e o Nginx vê IP de origem fora da tailnet — caindo no `deny all`
  # dos vhosts tailnet-only (s3-console, status) e do bloco `/admin` do
  # Vaultwarden.
  #
  # Requer cliente Tailscale com `--accept-dns=true` (default na role
  # tailscale_client).
  #
  # Lista declarativa em headscale_extra_dns_records (defaults/main.yml).
  # Sobrescreva no inventory para adicionar/remover entradas.
  extra_records:
{% for record in headscale_extra_dns_records %}
    - name: {{ record.name }}
      type: {{ record.type | default('A') }}
      value: {{ record.value }}
{% endfor %}

# Chaves de criptografia — geradas automaticamente em /var/lib/headscale
private_key_path: /var/lib/headscale/private.key
noise:
  private_key_path: /var/lib/headscale/noise_private.key

# Unix socket para CLI (headscale comando dentro do container)
unix_socket: /var/run/headscale/headscale.sock
unix_socket_permission: "0770"

# Tempo de validade de chaves de nó
node_update_check_interval: 10s
