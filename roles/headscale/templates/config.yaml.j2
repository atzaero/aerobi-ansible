# Headscale config — gerado pelo Ansible. Não editar manualmente.
# Para modificar: roles/headscale/templates/config.yaml.j2

server_url: https://{{ headscale_domain }}
listen_addr: 0.0.0.0:8080
metrics_listen_addr: 127.0.0.1:9090

# Endereços Tailscale para a tailnet (CGNAT range padrão)
prefixes:
  v4: 100.64.0.0/10
  v6: fd7a:115c:a1e0::/48
  allocation: sequential

# DERP — relays para NAT traversal. Usando relays públicos do Tailscale
# (ver doc/research/private-network.md sobre suporte oficial).
derp:
  server:
    enabled: false
  urls:
    - https://controlplane.tailscale.com/derpmap/default
  paths: []
  auto_update_enabled: true
  update_frequency: 24h

disable_check_updates: true
ephemeral_node_inactivity_timeout: 30m

# Banco de dados PostgreSQL (compartilhado com outras apps na mesma VPS)
database:
  type: postgres
  postgres:
    host: {{ postgres_container_name }}
    port: 5432
    name: {{ headscale_db }}
    user: {{ headscale_db_user }}
    pass: {{ vault_headscale_db_password }}
    ssl: false

# Logs
log:
  format: text
  level: info

# Política ACL (carregada em runtime; rebuild ao alterar acl.json)
policy:
  mode: file
  path: /etc/headscale/acl.json

# DNS — MagicDNS para resolver hostnames da tailnet
dns:
  magic_dns: true
  base_domain: aerobi.tailnet
  nameservers:
    global:
      - 1.1.1.1
      - 8.8.8.8

  # Override DNS para domínios públicos que devem ser resolvidos pelo IP
  # da tailnet quando o cliente está conectado. Sem isso, o navegador
  # resolve `vault.aerobi.com.br` pelo DNS público, o request sai pela
  # internet e o Nginx vê IP de origem fora da tailnet — caindo no `deny all`
  # do bloco `/admin`.
  #
  # Requer cliente Tailscale com `--accept-dns=true` (default na role
  # tailscale_client a partir desta mudança).
  extra_records:
    - name: vault.aerobi.com.br
      type: A
      value: 100.64.0.1

# Chaves de criptografia — geradas automaticamente em /var/lib/headscale
private_key_path: /var/lib/headscale/private.key
noise:
  private_key_path: /var/lib/headscale/noise_private.key

# Unix socket para CLI (headscale comando dentro do container)
unix_socket: /var/run/headscale/headscale.sock
unix_socket_permission: "0770"

# Tempo de validade de chaves de nó
node_update_check_interval: 10s
