# Virtual host: {{ headscale_domain }}
# Gerado automaticamente pelo Ansible — não edite manualmente.
# Para modificar: roles/headscale/templates/vhost.conf.j2
#
# NOTA: O bloco SSL será adicionado automaticamente pelo Certbot.
#
# Headscale usa gRPC + HTTP/2 sobre TLS para clientes; mantenha proxy_buffering off.

server {
    listen 80;
    server_name {{ headscale_domain }};

    location / {
        proxy_pass         http://127.0.0.1:{{ headscale_port }};
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # WebSocket / streaming — clientes Tailscale mantêm conexão longa
        proxy_http_version 1.1;
        proxy_set_header   Upgrade    $http_upgrade;
        proxy_set_header   Connection $http_connection;

        # Buffering off — Headscale faz streaming de updates de tailnet
        proxy_buffering off;
        proxy_request_buffering off;

        # Timeouts longos para conexões persistentes
        proxy_read_timeout  3600s;
        proxy_send_timeout  3600s;
    }
}
